# Founder Wall — frontend environment template.
#   cp .env.example .env.local
#
# NEXT_PUBLIC_ vars are inlined at BUILD time and are visible in the browser
# bundle — never put a secret here.

# Base URL of the Founder Wall API.
#   Local development against `python scripts/devserver.py` (or `make run`)
#   in ../backend:
NEXT_PUBLIC_API_URL=http://localhost:8000
#
#   In the shipped docker-compose, leave this EMPTY: nginx serves the API and
#   the frontend on one origin, so the browser calls /stats, /auth, /ws/wall
#   relative to the page. (compose sets the build arg to "" for you.)
# NEXT_PUBLIC_API_URL=

# Google OAuth client id for "Sign in with Google" (public — safe to inline).
# Leave empty for local development: the app then shows a dev "enter as a
# founder" button that works against a backend running with
# GOOGLE_ALLOW_INSECURE_TOKENS=true. Set a real client id for production.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=500137807777-6ium6ub9qjmd2bpji8s9pftici4i60sk.apps.googleusercontent.com
