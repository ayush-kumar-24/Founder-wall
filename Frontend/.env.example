# Founder Wall — frontend environment template.
#   cp .env.example .env.local
#
# Base URL of the Founder Wall API. NEXT_PUBLIC_ vars are inlined at build
# time and are visible in the browser bundle — never put a secret here.
#
# Local development against `make run` in ../backend:
NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Behind the shipped docker-compose (Nginx on :80) this is the site origin:
# NEXT_PUBLIC_API_URL=http://localhost
