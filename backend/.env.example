# Founder Wall — environment template.
#   cp .env.example .env
#
# THIS FILE IS COMMITTED. Every value below is a development default and none
# of them are safe for production. See docs/PRODUCTION.md before deploying.

# --- Runtime ---
# local | test | staging | production
# With ENVIRONMENT=production the app refuses to start on a weak or
# repo-published JWT_SECRET, on GOOGLE_ALLOW_INSECURE_TOKENS, or on DEBUG.
ENVIRONMENT=local
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true
# Interactive API docs. Forced off when ENVIRONMENT=production.
ENABLE_DOCS=true

# --- HTTP ---
PROJECT_NAME=Founder Wall
# "*", a comma-separated list, or a JSON array.
# A wildcard origin disables credentialed CORS (the spec forbids combining
# them). List real origins in production.
CORS_ORIGINS=*
# Trust X-Forwarded-For for client identity. Correct behind Nginx/an LB (as in
# docker-compose). Set false if the app is ever exposed directly — otherwise a
# client can forge the header and evade rate limiting.
TRUST_PROXY_HEADERS=true

# --- Database ---
POSTGRES_USER=founder
POSTGRES_PASSWORD=founder
POSTGRES_DB=founderwall
DATABASE_URL=postgresql+asyncpg://founder:founder@db:5432/founderwall
# Pool sizing is PER PROCESS. Total connections = DB_POOL_SIZE *
# WEB_CONCURRENCY * replicas, and must stay under Postgres max_connections
# (default 100). See docs/PRODUCTION.md.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
# Set to 0 when running behind PgBouncer in transaction pooling mode.
DB_STATEMENT_CACHE_SIZE=100
# Logs every statement and its parameters. Never enable in production.
DB_ECHO=false

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Security / JWT ---
# NEVER put a real secret in this file — it is committed, and a committed
# secret is a published one that every reader could forge tokens with. The
# placeholder below is explicitly rejected in production. Generate your own
# into .env (gitignored):
#
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=generate-your-own-do-not-use-this-value
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Skips Google ID-token signature verification. Local development only;
# production startup rejects this.
GOOGLE_ALLOW_INSECURE_TOKENS=false

# --- Wall geometry ---
WALL_COLUMNS=40
WALL_ROWS=25
TILE_SIZE=10
NOTE_MAX_LENGTH=280

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_PER_MINUTE=120
RATE_LIMIT_WRITE_PER_MINUTE=20

# --- Realtime ---
ONLINE_TTL_SECONDS=30
# Per-process WebSocket ceiling; the worker sheds new sockets beyond this.
WS_MAX_CONNECTIONS=10000

# --- Edge / compose ---
HTTP_PORT=80
# uvicorn worker processes per container (read natively by uvicorn).
WEB_CONCURRENCY=2
# Google OAuth client id for the FRONTEND build (public, inlined into the
# browser bundle). Leave empty to ship the dev "enter as a founder" button;
# set a real client id to enable production Google Sign-In. Consumed by the
# `web` service build in docker-compose.yml.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
