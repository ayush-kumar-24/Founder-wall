# ============================================================
# Founder Wall — production environment (Docker Compose on a VPS)
#
#   cp .env.example .env      then fill the REQUIRED SECRETS below.
#   THIS FILE IS COMMITTED — never put real secrets here. The real .env is
#   gitignored; never commit it.
#
# BUILD-TIME vs RUNTIME:
#   • NEXT_PUBLIC_* are inlined into the FRONTEND IMAGE at `docker compose build`.
#     Changing them requires a rebuild:  docker compose build web
#   • Every other variable is read at container RUNTIME — a restart applies it:
#     docker compose up -d
#
# MUST MATCH across services:
#   GOOGLE_CLIENT_ID (backend)  ==  NEXT_PUBLIC_GOOGLE_CLIENT_ID (frontend)
# ============================================================

# ------------------------------------------------------------
# REQUIRED SECRETS — generate fresh for production. Left empty on
# purpose: docker compose refuses to start until you set them.
# ------------------------------------------------------------
# Postgres password.   Generate:  openssl rand -base64 24
POSTGRES_PASSWORD=
# JWT signing secret.  Generate:  python3 -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=

# ------------------------------------------------------------
# GOOGLE OAUTH — the SAME client id goes in BOTH variables.
#   GOOGLE_CLIENT_ID              → backend, RUNTIME (token audience check)
#   NEXT_PUBLIC_GOOGLE_CLIENT_ID  → frontend, BUILD-TIME (renders the button)
# Required for real Google Sign-In. From Google Cloud → Credentials.
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Not used by the ID-token verifier — leave empty.
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------
# DEPLOYMENT CONFIG
# ------------------------------------------------------------
ENVIRONMENT=production
# Your public origin(s), comma-separated. Same-origin deploy doesn't require
# CORS, but set your domain for defense-in-depth.
CORS_ORIGINS=https://your-domain.com
# Host ports nginx binds on the VPS.
HTTP_PORT=80
HTTPS_PORT=443

# ------------------------------------------------------------
# POSTGRESQL
#   DATABASE_URL is CONSTRUCTED by docker-compose as
#   postgresql+asyncpg://<user>:<password>@db:5432/<db> — do NOT set it here.
# ------------------------------------------------------------
POSTGRES_USER=founder
POSTGRES_DB=founderwall

# ------------------------------------------------------------
# REDIS
#   REDIS_URL is set by docker-compose to redis://redis:6379/0 — do NOT set here.
# ------------------------------------------------------------

# ------------------------------------------------------------
# BACKEND RUNTIME (safe production defaults — change only if needed)
# ------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=true
ENABLE_DOCS=false
WEB_CONCURRENCY=2
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
# MUST be false in production (startup refuses true when ENVIRONMENT=production).
GOOGLE_ALLOW_INSECURE_TOKENS=false

# ------------------------------------------------------------
# OPTIONAL TUNING — defaults are production-sane; uncomment to override.
#   Total DB connections = DB_POOL_SIZE * WEB_CONCURRENCY; keep under
#   Postgres max_connections (default 100).
# ------------------------------------------------------------
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_RECYCLE_SECONDS=1800
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_DEFAULT_PER_MINUTE=120
# RATE_LIMIT_WRITE_PER_MINUTE=20
# WS_MAX_CONNECTIONS=10000
# ONLINE_TTL_SECONDS=30
# PRESENCE_BROADCAST_INTERVAL_SECONDS=5
# WALL_COLUMNS=40
# WALL_ROWS=25
# TILE_SIZE=10
# NOTE_MAX_LENGTH=280

# ------------------------------------------------------------
# ADMINER — no env needed. It targets the `db` host (set in compose) and is not
# publicly exposed; reach it via SSH tunnel (see Phase 6 / nginx notes).
# ------------------------------------------------------------
